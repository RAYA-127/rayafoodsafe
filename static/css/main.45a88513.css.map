/* ============================================================
   RayaFoods — RatingSystem.css (FIXED MOBILE VIEW)
   Place this file at:  src/Shopping Folder/AllComponents/RatingSystem.css
   ============================================================ */

.rating-system {
  max-width: 680px;
  margin: 2rem auto;
  font-family: 'Segoe UI', sans-serif;
  padding: 0 3rem;
}

/* ── Summary block ─────────────────────────────────────────── */
.rating-summary {
  display: flex;
  gap: 2rem;
  align-items: center;
  background: #f9f9f9;
  border: 1px solid #e0e0e0;
  border-radius: 14px;
  padding: 1.25rem 1.5rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}

.rating-score-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 90px;
}

.rating-big-num {
  font-size: 3rem;
  font-weight: 700;
  color: #015d01;
  line-height: 1;
  margin-bottom: 4px;
}

.rating-total-count {
  font-size: 13px;
  color: #777;
  margin-top: 4px;
}

.rating-bars {
  flex: 1;
  min-width: 200px;
}

.rating-bar-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 5px;
}

.rating-bar-label {
  font-size: 13px;
  color: #555;
  width: 24px;
  text-align: right;
  flex-shrink: 0;
}

.rating-bar-track {
  flex: 1;
  height: 8px;
  background: #e0e0e0;
  border-radius: 4px;
  overflow: hidden;
}

.rating-bar-fill {
  height: 100%;
  background: #015d01;
  border-radius: 4px;
  transition: width 0.4s ease;
}

.rating-bar-count {
  font-size: 12px;
  color: #888;
  width: 20px;
  text-align: left;
}

/* ── Stars ─────────────────────────────────────────────────── */
.star-picker {
  display: flex;
  gap: 6px;
  margin-top: 4px;
  justify-content: center;
}

.star-btn {
  background: #f5f5f5;
  border: 1px solid #ddd;
  border-radius: 8px;
  font-size: 1.8rem;
  cursor: pointer;
  color: #ccc;
  padding: 6px 10px;
  line-height: 1;
  transition: color 0.15s, transform 0.1s, background 0.15s;
}

.star-btn.filled,
.star-btn:hover {
  color: #f5a623;
  background: #fff8ee;
  border-color: #f5a623;
}

.star-btn:hover {
  transform: scale(1.15);
}

.star-display {
  display: inline-flex;
  gap: 1px;
}

.star-display--sm { font-size: 14px; }
.star-display--md { font-size: 22px; }

.star-display .filled { color: #f5a623; }
.star-display .empty  { color: #ddd; }

/* ── Form section ──────────────────────────────────────────── */
.rating-form-section {
  background-color: white;
  border-radius: 14px;
  padding: 30px;
  padding-left: 10px;
  padding-right: 48px;
  margin-bottom: 10px;
  box-sizing: border-box;
  width: 100%;
}

.rating-section-title {
  font-size: 16px;
  font-weight: 600;
  color: #222;
  margin: 0 0 1.2rem;
  text-align: center;
}

.rating-form {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  width: 100%;
}

.form-row {
  display: flex;
  flex-direction: column;
  gap: 6px;
  width: 100%;
  max-width: 420px;
  box-sizing: border-box;
}

.form-row label {
  font-size: 13px;
  font-weight: 500;
  color: #444;
  text-align: left;
}

.form-row input,
.form-row textarea {
  border: 1px solid #ccc;
  border-radius: 8px;
  padding: 9px 12px;
  font-size: 14px;
  font-family: inherit;
  outline: none;
  transition: border-color 0.2s;
  resize: vertical;
  width: 100%;
  box-sizing: border-box;
}

.form-row input:focus,
.form-row textarea:focus {
  border-color: #015d01;
  box-shadow: 0 0 0 3px rgba(1, 93, 1, 0.1);
}

.form-row--rating {
  align-items: center;
}

.form-row--rating label {
  text-align: center;
}

.rating-error {
  color: #c0392b;
  font-size: 13px;
  margin: 0;
  background: #fef0f0;
  padding: 8px 12px;
  border-radius: 6px;
  border: 1px solid #f5c6c6;
  width: 100%;
  max-width: 420px;
  box-sizing: border-box;
  text-align: center;
}

.rating-success {
  color: #1a6b1a;
  font-size: 13px;
  margin-bottom: 10px;
  background: #eafaea;
  padding: 10px 14px;
  border-radius: 8px;
  border: 1px solid #a8d5a8;
  width: 100%;
  max-width: 420px;
  box-sizing: border-box;
  text-align: center;
}

.submit-btn {
  background: #015d01;
  color: #ffffff;
  border: none;
  border-radius: 8px;
  padding: 11px 32px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s, transform 0.1s;
  width: 100%;
  max-width: 420px;
}

.submit-btn:hover  {
   background: #014501; 
  }
.submit-btn:active { 
  transform: scale(0.97); 
}

/* ── Reviews list ──────────────────────────────────────────── */
.reviews-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.review-card {
  background: #ffffff;
  border: 1px solid #e8e8e8;
  border-radius: 12px;
  padding: 1rem 1.25rem;
  transition: box-shadow 0.2s;
}

.review-card:hover {
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.review-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.review-avatar {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: #015d01;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 700;
  flex-shrink: 0;
}

.review-name {
  font-size: 14px;
  font-weight: 600;
  color: #222;
  margin: 0 0 2px;
}

.review-date {
  font-size: 12px;
  color: #aaa;
  margin-left: auto;
  white-space: nowrap;
}

.review-comment {
  font-size: 14px;
  color: #444;
  margin: 0;
  line-height: 1.6;
}

/* ── Empty state ───────────────────────────────────────────── */
.no-reviews {
  text-align: center;
  padding: 2rem;
  color: #999;
  font-size: 14px;
  background: #fafafa;
  border: 1px dashed #ddd;
  border-radius: 12px;
}

/* ── Mobile responsive ─────────────────────────────────────── */
@media (max-width: 480px) {
  .rating-system {
    padding: 0 12px; /* Reduces excessive root padding on small screens */
  }

  .rating-summary { 
    flex-direction: column;
    align-items: flex-start;
    padding: 1rem;
    gap: 1rem;
  }

  .rating-big-num { 
    font-size: 2.4rem;
  }

  .rating-form-section {
    padding: 20px 16px; /* Corrects asymmetric laptop layout paddings */
  }

  .star-picker {
    gap: 4px; /* Brings stars slightly closer together */
    width: 100%;
    justify-content: space-between; /* Ensures even item mapping distribution */
  }

  .star-btn {
    font-size: 1.4rem; /* Downscales star icons so they sit inside the bounding box */
    padding: 8px 0;    /* Converts static padding to structural block sizing */
    flex: 1;           /* Forces buttons to grow equally without clipping out */
    max-width: 55px;   /* Holds star dimensions inside standard viewports */
    text-align: center;
  }

  .form-row {
    max-width: 100%; 
  }

  .rating-error,
  .rating-success,
  .submit-btn {
    max-width: 100%;
  }
}